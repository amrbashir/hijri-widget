root = true

[*]
charset = utf-8
indent_style = tab
indent_size = 4
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

[*.{kt,kts}]
# TODO: Re-enable these rules after renaming packages/files and Compose/backing-property
# declarations to match ktlint's naming conventions.
ktlint_standard_backing-property-naming = disabled
ktlint_standard_filename = disabled
ktlint_standard_function-naming = disabled
ktlint_standard_package-name = disabled
